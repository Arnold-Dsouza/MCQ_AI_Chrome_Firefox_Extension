{
  "manifest_version": 3,
  "name": "MCQ AI",
  "version": "1.0.0",
  "description": "AI-powered MCQ solver — capture your screen, get the answer instantly.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_title": "MCQ AI",
    "default_icon": "icons/icon-32.png"
  },
  "action": {
    "default_title": "Open MCQ AI",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com;"
  }
}
